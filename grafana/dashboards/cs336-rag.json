{
  "uid": "cs336-rag-monitoring",
  "title": "CS336 Lecture Assistant \u2014 Monitoring",
  "tags": [
    "cs336",
    "rag"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "type": "stat",
      "title": "Total conversations",
      "datasource": {
        "type": "postgres",
        "uid": "cs336-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cs336-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS value FROM conversations",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": null,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "id": 1
    },
    {
      "type": "stat",
      "title": "Feedback rate",
      "datasource": {
        "type": "postgres",
        "uid": "cs336-postgres"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cs336-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT round(100.0 * (SELECT count(*) FROM feedback) / NULLIF(count(*),0), 1) AS value FROM conversations",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "fixed",
            "fixedColor": "purple"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "id": 2
    },
    {
      "type": "stat",
      "title": "Satisfaction (thumbs up)",
      "datasource": {
        "type": "postgres",
        "uid": "cs336-postgres"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cs336-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT round(100.0 * count(*) FILTER (WHERE rating=1) / NULLIF(count(*),0), 1) AS value FROM feedback",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "id": 3
    },
    {
      "type": "stat",
      "title": "Median answer latency",
      "datasource": {
        "type": "postgres",
        "uid": "cs336-postgres"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cs336-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT percentile_cont(0.5) WITHIN GROUP (ORDER BY total_ms) AS value FROM conversations",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "id": 4
    },
    {
      "type": "timeseries",
      "title": "Conversations over time",
      "datasource": {
        "type": "postgres",
        "uid": "cs336-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cs336-postgres"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, count(*) AS conversations FROM conversations WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "id": 5
    },
    {
      "type": "timeseries",
      "title": "Answer latency (p50 / p95)",
      "datasource": {
        "type": "postgres",
        "uid": "cs336-postgres"
      },
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cs336-postgres"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, percentile_cont(0.5) WITHIN GROUP (ORDER BY total_ms) AS \"p50\", percentile_cont(0.95) WITHIN GROUP (ORDER BY total_ms) AS \"p95\" FROM conversations WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "id": 6
    },
    {
      "type": "timeseries",
      "title": "Token usage over time (avg per answer)",
      "datasource": {
        "type": "postgres",
        "uid": "cs336-postgres"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cs336-postgres"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, avg(prompt_tokens) AS \"prompt\", avg(completion_tokens) AS \"completion\" FROM conversations WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "id": 7
    },
    {
      "type": "timeseries",
      "title": "Latency breakdown (retrieval vs generation)",
      "datasource": {
        "type": "postgres",
        "uid": "cs336-postgres"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "cs336-postgres"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, avg(retrieval_ms) AS \"retrieval\", avg(generation_ms) AS \"generation\" FROM conversations WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "smooth",
            "fillOpacity": 70,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "id": 8
    },
