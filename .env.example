# API key for the OpenAI-compatible endpoint (https://api.nan.builders/v1)
OPENAI_KEY=sk-your-key-here

# Optional overrides (defaults shown)
# LLM_BASE_URL=https://api.nan.builders/v1
# CHAT_MODEL=qwen3.6
# EMBEDDING_MODEL=qwen3-embedding
# EMBEDDING_DIM=1024
# RERANK_MODEL=rerank
# WHISPER_MODEL=whisper
# JUDGE_MODEL=deepseek-v4-flash

# RAG behaviour (defaults shown)
# RETRIEVAL_METHOD=vector       # winner of the retrieval evaluation
# RAG_PROMPT_VARIANT=grounded   # winner of the answer evaluation
# RAG_CONTEXT_SIZE=5
# CHAT_DISABLE_THINKING=true    # qwen3.6 reasoning mode off (see docs/evaluation.md)
# RAG_REWRITE_QUERY=false       # rewrite messy questions before retrieval (see docs/evaluation.md)

# Ingestion/data layout (defaults shown)
# DATA_DIR=data
# CHUNK_MAX_CHARS=1800
# CHUNK_OVERLAP_CHARS=300
# EMBED_BATCH_SIZE=64
# PLAYLIST_ID=PLoROMvodv4rMqXOcazWaTUHhq-yembLCV

# App (docker-compose)
# APP_PORT=8000

# Postgres (docker-compose provides these defaults)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=cs336_rag
# DB_USER=cs336
# DB_PASSWORD=cs336

# Grafana (docker-compose)
# GRAFANA_PORT=3000
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=admin
# GRAFANA_ANONYMOUS_ENABLED=false
